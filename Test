        },
        AttackType = "Blade",
        IsNegative2 = false,
        VelocityForce = 1000,
        ClientFunction = function() end
    }
end

local function FireInstantKill()
    local swingRemote = GetSwingRemote()
    if swingRemote then
        local args = GetModifiedArgs()
        swingRemote:FireServer(args)
        print("⚔️ INSTANT KILL FIRED! Damage:", instantKillDamage)
        return true
    end
    return false
end

local function StartInstantKillSpam()
    if instantKillThread then return end
    instantKillThread = task.spawn(function()
        while instantKillEnabled do
            local now = tick()
            if now - lastInstantKillTime >= instantKillDelay then
                local success = FireInstantKill()
                if success then
                    lastInstantKillTime = now
                else
                    task.wait(0.5)
                end
            end
            task.wait(0.05)
        end
        instantKillThread = nil
    end)
end

local function StopInstantKillSpam()
    if instantKillThread then
        task.cancel(instantKillThread)
        instantKillThread = nil
    end
end

-- ===== FAST REGENERATION =====
local fastRegenEnabled = false
local fastRegenAmount = 10000
local fastRegenThread = nil

local function StartFastRegen()
    if fastRegenThread then return end
    fastRegenThread = task.spawn(function()
        while fastRegenEnabled and character and humanoid do
            pcall(function()
                local newHealth = humanoid.Health + fastRegenAmount
                if newHealth < 0 then newHealth = 0 end
                if newHealth > humanoid.MaxHealth then newHealth = humanoid.MaxHealth end
                humanoid.Health = newHealth
            end)
            task.wait(1)
        end
        fastRegenThread = nil
    end)
end

local function StopFastRegen()
    if fastRegenThread then
        task.cancel(fastRegenThread)
        fastRegenThread = nil
    end
end

local function FindDodgeRemote()
    pcall(function()
        if character then
            local staminaHandler = character:FindFirstChild("StaminaHandler")
            if staminaHandler then
                dodgeRemote = staminaHandler:FindFirstChild("Dodge")
            end
        end
    end)
    return dodgeRemote ~= nil
end

local function DoStamina()
    pcall(function()
        if character then
            local tool = character:FindFirstChild("Longsword")
            if tool and tool:FindFirstChild("Events") then
                local swingRemote = tool.Events:FindFirstChild("Swing")
                if swingRemote then
                    swingRemote:FireServer(unpack(swingArgs))
                end
            end
        end
    end)
end

local function StartStaminaSpam()
    if staminaSpamThread then return end
    staminaSpamThread = task.spawn(function()
        while staminaSpamEnabled do
            DoStamina()
            task.wait(staminaInterval)
        end
        staminaSpamThread = nil
    end)
end

local function StopStaminaSpam()
    if staminaSpamThread then task.cancel(staminaSpamThread) staminaSpamThread = nil end
end

local function DoDodge()
    pcall(function()
        if dodgeRemote then
            dodgeRemote:FireServer()
            print("💨 DODGE EXECUTED!")
        end
    end)
end

local function StartNoStun()
    if stunThread then return end
    stunThread = task.spawn(function()
        while noStunEnabled and character and humanoid do
            pcall(function()
                if humanoid.WalkSpeed < originalWalkSpeed - 5 then
                    humanoid.WalkSpeed = originalWalkSpeed
                end
                if humanoid.PlatformStand then
                    humanoid.PlatformStand = false
                end
            end)
            task.wait(0.1)
        end
        stunThread = nil
    end)
end

local function StopNoStun()
    if stunThread then task.cancel(stunThread) stunThread = nil end
    pcall(function()
        if character and humanoid then
            humanoid.WalkSpeed = originalWalkSpeed
            humanoid.PlatformStand = false
        end
    end)
end

