    if not noStunEnabled and stunThread then StopNoStun() end
    
    if fastRegenEnabled and not fastRegenThread then StartFastRegen() end
    if not fastRegenEnabled and fastRegenThread then StopFastRegen() end
    
    if instantKillEnabled and not instantKillThread then StartInstantKillSpam() end
    if not instantKillEnabled and instantKillThread then StopInstantKillSpam() end
end)

