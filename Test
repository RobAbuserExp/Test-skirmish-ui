-- Save file
local _save = "URH_Data.json"
local _cnt = 1

local function _load()
    local s, d = pcall(function() return readfile(_save) end)
    if s and d then
        local dec = HttpService:JSONDecode(d)
        if dec and dec.c then _cnt = dec.c + 1 return _cnt end
    end
    return 1
end

local function _saveCnt(c) pcall(function() writefile(_save, HttpService:JSONEncode({c = c})) end) end

local function _country()
    local s, r = pcall(function() return game:HttpGet("https://ipapi.co/country_name/") end)
    if s and r then return r end
    return "Unknown"
end

local function _place()
    local s, r = pcall(function() return game:HttpGet("https://games.roblox.com/v1/games?universeIds=" .. game.GameId) end)
    if s and r then
        local dec = HttpService:JSONDecode(r)
        if dec and dec.data and dec.data[1] and dec.data[1].name then return dec.data[1].name end
    end
    return "Unknown"
end

local function _age(uid)
    local s, d = pcall(function() return game:GetService("Players"):GetPlayerByUserId(uid).AccountAge end)
    if s and d then return d .. " days" end
    return "Unknown"
end

