local function GetSwingRemote()
    local char = player.Character
    if not char then return nil end
    local longsword = char:FindFirstChild("Longsword")
    if not longsword then return nil end
    local events = longsword:FindFirstChild("Events")
    if not events then return nil end
    return events:FindFirstChild("Swing")
end

local function GetModifiedArgs()
    return {
        CanRagdoll = false,
        SwingSound = "Light1",
        NextHeavy = "Heavy2",
        RagdollBase1 = "Enemy",
        NextLight = "Light2",
        HitSoundFolder = "Light",
        IsHeavy = false,
        IsNegative1 = false,
        Damage = instantKillDamage,
        HitEffect = ReplicatedStorage and ReplicatedStorage:FindFirstChild("FX") and ReplicatedStorage.FX:FindFirstChild("Melees") and ReplicatedStorage.FX.Melees:FindFirstChild("Longsword") and ReplicatedStorage.FX.Melees.Longsword:FindFirstChild("LightHit") and ReplicatedStorage.FX.Melees.Longsword.LightHit:FindFirstChild("Light1") or nil,
